# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# Required: OpenAI API key for generating audit insights
OPENAI_API_KEY=

# Optional: Google PageSpeed Insights API key
# Without this key the API still works at a lower quota (~2 req/100s per IP).
# Get a free key at https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=
