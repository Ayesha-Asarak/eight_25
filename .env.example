# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# Required: Google Gemini API key for generating audit insights
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override Gemini model (default: gemini-2.5-flash-lite — highest free-tier quota)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: Google PageSpeed Insights API key
# Without this key the API still works at a lower quota (~2 req/100s per IP).
# Get a free key at https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=
